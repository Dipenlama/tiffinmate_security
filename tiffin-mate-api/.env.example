# Copy this file to .env and fill in real values. Never commit the real .env file.

NODE_ENV=development
PORT=5050

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/tiffinMate

# Comma-separated list of frontend origins allowed to call this API with credentials
ALLOWED_ORIGINS=http://localhost:3000

# Secret used to sign/verify short-lived JWT access tokens.
# Must be at least 32 random characters. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ACCESS_TOKEN_SECRET=

# Secret used to sign/verify rotating refresh tokens. Must differ from ACCESS_TOKEN_SECRET.
REFRESH_TOKEN_SECRET=

# AES-256 key (exactly 64 hex chars / 32 bytes) used to encrypt MFA TOTP secrets at
# rest - required, the server refuses to boot without it. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Rotating this key makes existing users' stored MFA secrets undecryptable.
MFA_ENCRYPTION_KEY=

# Stripe settings (optional - payment flow falls back to a mock success path if unset)
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Frontend origin used to build Stripe redirect URLs
FRONTEND_URL=http://localhost:3000

# CAPTCHA (hCaptcha) - optional in development/test (verification is skipped with a
# warning if unset), but required in production (server refuses to boot without it).
# Protects /register, /login, and /forgot-password from automated abuse.
# Get keys at https://dashboard.hcaptcha.com/
CAPTCHA_SECRET_KEY=
CAPTCHA_SITE_KEY=
