# Copy to `.env` in this same directory (next to docker-compose.yml) and fill
# in real values - docker-compose loads it automatically. Never commit the
# real `.env`.

# Secret used to sign/verify JWT access tokens (>= 32 chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ACCESS_TOKEN_SECRET=

# AES-256 key (exactly 64 hex chars) used to encrypt MFA TOTP secrets at rest.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MFA_ENCRYPTION_KEY=

# hCaptcha secret key (optional in development; required for NODE_ENV=production).
CAPTCHA_SECRET_KEY=

# Origin(s) allowed to call the API with credentials.
ALLOWED_ORIGINS=http://localhost:3000

# Frontend origin used to build Stripe redirect URLs.
FRONTEND_URL=http://localhost:3000

# Stripe (optional - payment flow falls back to a mock success path if unset).
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=
STRIPE_PUBLISHABLE_KEY=

# Baked into the frontend's client bundle at build time.
NEXT_PUBLIC_API_ORIGIN=http://localhost:5050
NEXT_PUBLIC_API_PREFIX=/api
